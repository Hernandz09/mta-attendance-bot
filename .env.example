# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Canal donde vive el panel de botones de asistencia (#asistencias)
ATTENDANCE_CHANNEL_ID=
# Opcional en desarrollo: registro instantáneo de comandos en un servidor
DISCORD_GUILD_ID=

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Pegar la clave privada entre comillas, con \n para los saltos de línea
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Dashboard interno (opcionales: si faltan, el bot solo escribe en Sheets)
# URL base del backend, sin barra final (ej: https://miapp.com)
DASHBOARD_API_URL=
# Clave secreta compartida con el backend (header x-api-key)
ATTENDANCE_BOT_API_KEY=

# Zona horaria (ej: America/Lima, America/Mexico_City)
TIMEZONE=America/Lima
